@using MudBlazor
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using CareerOps.Application.DTOs
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject JobApiClient JobClient

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @( _isEdit ? "Editar Oportunidade" : "Cadastrar Nova Oportunidade" )
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            <MudTextField @bind-Value="_request.Company" Label="Empresa" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_request.JobTitle" Label="Título da Vaga" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_request.Description" Label="Descrição da Vaga" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_request.URL" Label="URL da Vaga" Variant="Variant.Outlined" Required="true" />

            @* Sintaxe MudBlazor v7: O botão é o conteúdo direto *@
            <MudFileUpload T="IBrowserFile" FilesChanged="HandleFileSelected" Class="mt-2">
                <MudButton HtmlTag="label"
                           Variant="Variant.Filled"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.CloudUpload">
                    @(_file == null ? "Upload Currículo (PDF)" : _file.Name)
                </MudButton>
            </MudFileUpload>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(_loading || !IsFormValid())">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {

                <MudText>Iniciar Análise</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public JobApplicationResponse? JobToEdit { get; set; }

    private JobApplicationRequest _request = new();
    private IBrowserFile? _file;
    private bool _loading;
    private bool _isEdit => JobToEdit != null;

    private void HandleFileSelected(IBrowserFile file) => _file = file;
    private void Cancel() => MudDialog.Cancel();

    private bool IsFormValid() =>
        !string.IsNullOrWhiteSpace(_request.Company) &&
        !string.IsNullOrWhiteSpace(_request.JobTitle) &&
        !string.IsNullOrWhiteSpace(_request.Description) &&
        !string.IsNullOrWhiteSpace(_request.URL) &&
        _file != null;


    protected override void OnParametersSet()
    {
        if (_isEdit && JobToEdit != null)
        {
            // Mapeamento MANUAL dos dados para o formulário
            _request.Company = JobToEdit.Company;
            _request.JobTitle = JobToEdit.JobTitle;
            _request.Description = JobToEdit.Description;
            _request.URL = JobToEdit.URL;
            _request.SalaryRange = JobToEdit.SalaryRange;
            _request.ApplicationStatus = JobToEdit.ApplicationStatus;
        }
    }

    private async Task Submit()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            if (_isEdit)
            {
                await JobClient.UpdateJobAsync(JobToEdit!.Id, _request);
                Snackbar.Add("Vaga atualizada com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                // Timeout manual para não esperar a vida toda
                using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));

                var createResponse = await Http.PostAsJsonAsync("api/jobs", _request, cts.Token);

                if (!createResponse.IsSuccessStatusCode)
                {
                    var error = await createResponse.Content.ReadAsStringAsync();
                    return;
                }

                var jobDto = await createResponse.Content.ReadFromJsonAsync<JobApplicationResponse>();

                if (jobDto != null && _file != null)
                {
                    using var content = new MultipartFormDataContent();

                    var fileStream = _file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                    var fileContent = new StreamContent(fileStream);

                    fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_file.ContentType);

                    content.Add(fileContent, "file", _file.Name);

                    var uploadResponse = await Http.PostAsync($"api/jobs/{jobDto.Id}/resume", content);

                    if (uploadResponse.IsSuccessStatusCode)
                    {
                        Snackbar.Add("Vaga e Currículo enviados!", Severity.Success);
                        MudDialog.Close(DialogResult.Ok(true));
                    }
                    else
                    {
                        var uploadError = await uploadResponse.Content.ReadAsStringAsync();
                        Snackbar.Add("Vaga criada, mas falha ao subir PDF.", Severity.Warning);
                    }
                }
            }
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine("ERRO: A API demorou demais para responder (Timeout).");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"CRASH: {ex.GetType().Name} - {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

}